DOMAIN=beta.example.com
POSTGRES_PASSWORD=replace-with-at-least-32-random-characters
ADMIN_EMAILS=owner@example.com
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace-with-server-side-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
ADVISOR_DAILY_LIMIT=30

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM=OfferPilot <no-reply@example.com>
SMTP_USE_TLS=true

SESSION_TTL_HOURS=168
AUTH_RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_MINUTE=120
BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_SECONDS=86400
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
APP_RELEASE=offerpilot-api@0.4.0

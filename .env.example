NEXT_PUBLIC_API_URL=http://localhost:8000
# Vercel Services injects NEXT_PUBLIC_API_URL=/api automatically for the api service.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Hosted fast path: only the server operator configures this key; end users never provide one.
AGENT_MODE=llm-assisted
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
ADVISOR_DAILY_LIMIT=30

# Optional offline mode. It is never used as an implicit DeepSeek fallback.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b

CORS_ORIGINS=http://localhost:3000
SESSION_TTL_HOURS=168
APP_ENV=development
APP_URL=http://localhost:8080
ADMIN_EMAILS=admin@offerpilot.local
AUTH_RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_MINUTE=120
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
APP_RELEASE=offerpilot-api@0.4.0

# Required in production for verification and password-reset email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=OfferPilot <no-reply@example.com>
SMTP_USE_TLS=true

# Set this to persist users, profiles and Agent runs across API restarts.
DATABASE_PATH=./data/offerpilot.db
# Production takes precedence over DATABASE_PATH when both are present.
DATABASE_URL=

NEXT_PUBLIC_API_URL=http://localhost:8000
# Vercel Services injects NEXT_PUBLIC_API_URL=/api automatically for the api service.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# The API automatically enables the LLM advisor when a server-side key exists.
# Never prefix this key with NEXT_PUBLIC_ and never commit a real value.
AGENT_MODE=llm-assisted
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini
CORS_ORIGINS=http://localhost:3000

# Set this to persist users, profiles and Agent runs across API restarts.
DATABASE_PATH=./data/offerpilot.db
